{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Mobile parts or accessories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "category": { "type": "string", "enum": ["part", "accessory"] },
        "image": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "price", "category", "image"]
    },
    "User": {
      "title": "User",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "village": { "type": "string" },
        "buildingNo": { "type": "string" },
        "city": { "type": "string" },
        "district": { "type": "string" },
        "state": { "type": "string" },
        "pinCode": { "type": "string" }
      },
      "required": ["name", "mobile"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/entities/Product" } },
        "customer": { "$ref": "#/entities/User" }
      },
      "required": ["id", "date", "total", "status", "items", "customer"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products available in the shop"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and customer details"
    }
  }
}
