rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'niteshk142udhd@gmail.com' &&
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entities
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'category', 'image']) &&
             data.keys().size() >= 5 &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category in ['part', 'accessory'] &&
             data.image is string && data.image.size() <= 1000;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'mobile']) &&
             data.name is string && data.name.size() <= 100 &&
             data.mobile is string && data.mobile.size() == 10 &&
             (!data.keys().contains('pinCode') || (data.pinCode is string && data.pinCode.size() <= 10));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'date', 'total', 'status', 'items', 'customer']) &&
             data.id is string &&
             data.total is number && data.total >= 0 &&
             data.status is string &&
             data.items is list && data.items.size() > 0 &&
             isValidUser(data.customer);
    }

    // Collections
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'originalPrice', 'category', 'image', 'description'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Allow customers to see their orders by mobile number even without auth session
      allow list: if isAdmin() || (resource.data.customer.mobile != null);
      allow get: if isAdmin() || true; 
      allow create: if isValidOrder(incoming()) && isValidId(orderId);
      allow update: if isAdmin() && isValidOrder(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Allow direct profile sync using mobile ID pattern
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin() || (userId == 'user_' + incoming().mobile && isValidUser(incoming()));
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
